# ════════════════════════════════════════════════════════════════════════
#  Rachio Data Collector — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ════════════════════════════════════════════════════════════════════════

# ── Rachio ───────────────────────────────────────────────────────────────
# Found in the Rachio app: Account → API Access
RACHIO_API_KEY=your_rachio_api_key_here

# How many seconds back to look for events on each poll (default: 300 = 5 min)
# Should match or slightly exceed POLL_INTERVAL_EVENTS to avoid gaps
RACHIO_EVENT_LOOKBACK_SECONDS=300


# ── Elasticsearch Serverless ─────────────────────────────────────────────
# Your serverless ES endpoint (no trailing slash)
# Found in: Elastic Cloud → Your Deployment → Manage → Copy endpoint
ES_ENDPOINT=https://your-deployment.es.us-east-1.aws.elastic.cloud

# API key with write permissions to rachio-* indices
# Create in: Kibana → Stack Management → API Keys → Create API Key
# Permissions needed: index, create_index on rachio-*
ES_API_KEY=your_base64_encoded_api_key_here

# Namespace segment in ECS-aligned stream names: {type}-rachio.{dataset}-{namespace}
# Streams created: logs-rachio.events-default, metrics-rachio.devices-default, etc.
ES_NAMESPACE=default

# Max retries on ES write failure (default: 3)
ES_MAX_RETRIES=3


# ── Elastic APM / OpenTelemetry ───────────────────────────────────────────
# Your Elastic APM Server OTLP endpoint
# Found in: Kibana → Observability → Add data → APM → OpenTelemetry
# Format: https://<your-apm-id>.apm.<region>.aws.elastic.cloud
OTEL_EXPORTER_OTLP_ENDPOINT=https://your-apm-id.apm.us-east-1.aws.elastic.cloud

# Authentication header for the APM endpoint
# IMPORTANT: gRPC requires all header keys to be lowercase.
# Use the secret token from your APM Server configuration:
#   authorization=Bearer your_apm_secret_token
# Or an API key:
#   authorization=ApiKey your_base64_api_key
OTEL_EXPORTER_OTLP_HEADERS=authorization=Bearer your_apm_secret_token_here

# How often (ms) to export metrics to Elastic APM (default: 30000 = 30s)
OTEL_METRIC_EXPORT_INTERVAL_MS=30000


# ── Polling Intervals (seconds) ───────────────────────────────────────────
# Device status + current running schedule
POLL_INTERVAL_DEVICE=60

# Zone state, moisture levels, last/next run data
POLL_INTERVAL_ZONES=300

# Device event history (watering start/stop, errors, rain delays)
POLL_INTERVAL_EVENTS=120

# Weather forecast for device location
POLL_INTERVAL_WEATHER=1800

# Schedule rules (fixed + flex)
POLL_INTERVAL_SCHEDULES=900


# ── Application ───────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=production
